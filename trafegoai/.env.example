# ===== TrafegoAI — variáveis de ambiente =====
# Copie para .env e preencha. Em desenvolvimento, os defaults do docker-compose funcionam.

# --- Core ---
DATABASE_URL=postgresql://trafegoai:trafegoai@localhost:5432/trafegoai
REDIS_URL=redis://localhost:6379
JWT_SECRET=troque-por-um-segredo-forte
# Chave AES-256 (32 bytes em hex) usada para criptografar tokens OAuth em repouso (LGPD)
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Google Ads API ---
# 1. Crie um projeto no Google Cloud Console e ative a Google Ads API
# 2. Solicite um Developer Token em https://ads.google.com/aw/apicenter
# 3. Crie credenciais OAuth 2.0 (tipo Web) com redirect: {API_URL}/connections/google/callback
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# --- Meta Marketing API (Facebook/Instagram) ---
# 1. Crie um app em https://developers.facebook.com (tipo Business)
# 2. Adicione o produto "Marketing API" e solicite acesso avançado a ads_read/ads_management
# 3. Redirect OAuth: {API_URL}/connections/meta/callback
META_APP_ID=
META_APP_SECRET=

# --- TikTok Marketing API ---
# 1. Registre-se em https://business-api.tiktok.com e crie um app de desenvolvedor
# 2. Solicite os escopos de Ads Management (requer aprovação do app)
# 3. Redirect OAuth: {API_URL}/connections/tiktok/callback
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# --- Radar de Tendências ---
# YouTube Data API v3 (REAL): vídeos "Em alta" por país no Radar.
# Crie a chave em https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=
# TikTok Creative Center / Google Trends / marketplaces: pontos de integração
# documentados em apps/api/src/radar/radar.service.ts (sem chave = dados curados)

# --- IA (diagnósticos, recomendações, chat, criativos) ---
# Recomendado: Claude (https://console.anthropic.com). Sem chave, a IA roda em modo mock/heurístico.
ANTHROPIC_API_KEY=

# --- Stripe (planos Starter/Pro/Agência) ---
# Sem STRIPE_SECRET_KEY, o checkout roda em modo demo (aplica o plano sem cobrar).
# Com a chave, crie os Prices no Stripe (mensal e anual) e cole os IDs abaixo.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_AGENCY=
STRIPE_PRICE_AGENCY_ANNUAL=

# --- Auth Google (login do usuário) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
