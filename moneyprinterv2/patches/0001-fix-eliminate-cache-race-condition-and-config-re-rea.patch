 ROOT_DIR = os.path.dirname(sys.path[0])
 
+# In-memory cache of the parsed config.json, keyed by the file's
+# (mtime, size) signature. The file is only re-read from disk when it actually
+# changes on disk, so the 30+ getters below stop hitting the filesystem on
+# every single call while still picking up edits to config.json.
+_config_cache = None
+_config_signature = None
+
+def _config_path() -> str:
+    """
+    Returns the absolute path to config.json.
+    """
+    return os.path.join(ROOT_DIR, "config.json")
+
+def _read_config() -> dict:
+    """
+    Reads and parses config.json, caching the result until the file changes.
+
+    The cache is invalidated whenever the file's modification time or size
+    changes, so callers always observe the latest on-disk config without
+    re-parsing the file on every access.
+
+    Returns:
+        config (dict): The parsed configuration
+    """
+    global _config_cache, _config_signature
+
+    path = _config_path()
+    stat = os.stat(path)
+    signature = (stat.st_mtime_ns, stat.st_size)
+
+    if _config_cache is None or signature != _config_signature:
+        with open(path, "r") as file:
+            _config_cache = json.load(file)
+        _config_signature = signature
+
+    return _config_cache
+
