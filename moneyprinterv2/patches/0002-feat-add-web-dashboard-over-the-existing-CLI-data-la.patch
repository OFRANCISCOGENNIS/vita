+<script>
+const $ = s => document.querySelector(s);
+const esc = s => String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
+
+function toast(msg){
+  const t = $('#toast'); t.textContent = msg; t.classList.add('show');
+  clearTimeout(t._h); t._h = setTimeout(()=>t.classList.remove('show'), 2600);
+}
+
+async function api(path, opts={}){
+  const r = await fetch('/api'+path, {headers:{'Content-Type':'application/json'}, ...opts});
+  if (r.status === 204) return null;
+  const body = await r.json().catch(()=>null);
+  if (!r.ok) throw new Error(body && body.detail ? (typeof body.detail==='string'?body.detail:JSON.stringify(body.detail)) : r.statusText);
+  return body;
+}
+
+document.querySelectorAll('nav.tabs button').forEach(btn=>{
+  btn.addEventListener('click', ()=>{
+    document.querySelectorAll('nav.tabs button').forEach(b=>b.setAttribute('aria-selected','false'));
+    btn.setAttribute('aria-selected','true');
+    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
+    $('#p-'+btn.dataset.tab).classList.add('on');
+  });
+});
+
+async function loadStatus(){
+  const s = await api('/status');
+  $('#stat-cards').innerHTML = [
+    ['Contas YouTube', s.youtube_accounts], ['Contas Twitter', s.twitter_accounts],
+    ['Vídeos', s.videos], ['Posts', s.posts], ['Produtos', s.products],
+  ].map(([l,n])=>`<div class="card"><div class="n">${n}</div><div class="l">${l}</div></div>`).join('');
+  const pill = $('#ollama-pill');
+  if (s.ollama.reachable){ pill.className='pill ok'; pill.textContent=`ollama: ok (${s.ollama.models.length} modelos)`; }
+  else { pill.className='pill err'; pill.textContent='ollama: fora do ar'; }
+}
+
+async function loadYouTube(){
+  const list = await api('/accounts/youtube');
+  $('#yt-rows').innerHTML = list.length ? list.map(a=>`<tr>
+    <td>${esc(a.nickname)}</td><td>${esc(a.niche)}</td><td>${esc(a.language)}</td>
+    <td>${(a.videos||[]).length}</td><td class="mono">${a.id}</td>
+    <td><button class="del" data-prov="youtube" data-id="${a.id}">remover</button></td></tr>`).join('')
+    : '<tr><td colspan="6" class="empty">Nenhuma conta ainda — crie a primeira abaixo.</td></tr>';
+}
+
+async function loadTwitter(){
+  const list = await api('/accounts/twitter');
+  $('#tw-rows').innerHTML = list.length ? list.map(a=>`<tr>
+    <td>${esc(a.nickname)}</td><td>${esc(a.topic)}</td>
+    <td>${(a.posts||[]).length}</td><td class="mono">${a.id}</td>
+    <td><button class="del" data-prov="twitter" data-id="${a.id}">remover</button></td></tr>`).join('')
+    : '<tr><td colspan="5" class="empty">Nenhuma conta ainda — crie a primeira abaixo.</td></tr>';
+}
+
+async function loadAfm(){
+  const list = await api('/products');
+  $('#afm-rows').innerHTML = list.length ? list.map(p=>`<tr>
+    <td>${esc(p.affiliate_link)}</td><td class="mono">${esc(p.twitter_uuid)}</td><td class="mono">${p.id}</td></tr>`).join('')
+    : '<tr><td colspan="3" class="empty">Nenhum produto cadastrado.</td></tr>';
+}
+
+async function loadConfig(){
+  $('#cfg-view').textContent = JSON.stringify(await api('/config'), null, 2);
+}
+
+function bindForm(sel, path, after){
+  $(sel).addEventListener('submit', async e=>{
+    e.preventDefault();
+    const data = Object.fromEntries(new FormData(e.target).entries());
+    try{ await api(path, {method:'POST', body:JSON.stringify(data)}); e.target.reset(); toast('Criado.'); after(); loadStatus(); }
+    catch(err){ toast('Erro: '+err.message); }
+  });
+}
+bindForm('#yt-form','/accounts/youtube', loadYouTube);
+bindForm('#tw-form','/accounts/twitter', loadTwitter);
+bindForm('#afm-form','/products', loadAfm);
+
+document.addEventListener('click', async e=>{
+  const b = e.target.closest('button.del'); if(!b) return;
+  if(!confirm('Remover esta conta?')) return;
+  try{ await api(`/accounts/${b.dataset.prov}/${b.dataset.id}`, {method:'DELETE'});
+    toast('Removida.'); loadYouTube(); loadTwitter(); loadStatus(); }
+  catch(err){ toast('Erro: '+err.message); }
+});
+
+loadStatus(); loadYouTube(); loadTwitter(); loadAfm(); loadConfig();
+</script>
+</body>
+</html>
