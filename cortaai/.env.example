# CortaAí — variáveis de ambiente
# Copie para .env na raiz de cortaai/ antes de rodar docker compose.
# TODAS as chaves abaixo são opcionais em desenvolvimento: sem elas a
# plataforma roda em modo demo (mocks determinísticos e seed pré-populado).

# Segurança
JWT_SECRET=troque-em-producao

# INTEGRAÇÃO PAGA: Stripe (checkout e webhooks de assinatura)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# INTEGRAÇÃO PAGA: YouTube Data API v3 (Radar Viral — tendências reais)
YOUTUBE_API_KEY=

# INTEGRAÇÃO PAGA: LLM para score viral, títulos, hashtags e relatórios Raio-X
# (preencha um dos dois; os prompts estão documentados em apps/api/app/services/llm.py)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# INTEGRAÇÃO PAGA: Google OAuth (login com Google)
GOOGLE_OAUTH_CLIENT_ID=
